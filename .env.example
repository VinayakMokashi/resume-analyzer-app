# ---- Required ----
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# ---- Optional: override the Groq model (defaults to qwen/qwen3-32b) ----
# See live models: https://console.groq.com/docs/models
# GROQ_MODEL=qwen/qwen3-32b

# ---- Optional: AWS (S3 + DynamoDB). Leave blank to run without cloud storage. ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ---- Optional: override AWS resource names (defaults shown) ----
# S3_BUCKET=resume-analyzer-app-bucket
# DYNAMODB_TABLE=resume-analyzer
